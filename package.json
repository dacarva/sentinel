{
  "name": "zk-credit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["mock-bank","app","backend","plugin-sdk", "tlsn-common", "plugin", "plugin-bancolombia"],
  "scripts": {
    "bank:start": "bun run --filter mock-bank start",
    "app:dev": "bun run --filter app dev",
    "app:build": "bun run plugin:build && bun run circuit:build && bun run --filter app build",
    "app:lint": "bun run --filter app lint",
    "app:preview": "bun run --filter app preview",
    "sentinel:start": "bun run --filter backend start",
    "sentinel:start:inspect": "bun run --filter backend start:inspect",
    "sentinel:start:inspect:brk": "bun run --filter backend start:inspect:brk",
    "plugin:build": "bun run --filter @tlsn/ts-plugin-bancolombia build && cp plugin-bancolombia/build/ts-plugin-bancolombia.js app/public/ts-plugin-bancolombia.js",
    "circuit:build": "cd circuit && nargo compile && bb write_vk -b target/balance_threshold.json -o target/ && cp target/balance_threshold.json ../app/public/circuit.json",
    "circuit:test": "cd circuit && nargo test",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
