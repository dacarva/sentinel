# Sentinel backend API base URL (for POST /attest)
VITE_SENTINEL_API=http://localhost:3000

# TLSNotary plugin JS URL (Mock Bank plugin when built)
# Default: /ts-plugin-sample.js (run "bun run plugin:build" from repo root first)
# Do NOT set to a .wasm URL; the app uses the JS plugin and execCode().
# VITE_TLSN_PLUGIN_URL=/ts-plugin-sample.js
