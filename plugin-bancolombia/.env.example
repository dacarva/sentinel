# Bancolombia plugin build-time config (VERIFIER_URL, PROXY_URL).
# Local: copy to .env and set values.
# Vercel: add VERIFIER_URL and PROXY_URL in Project Settings → Environment Variables
#         (they are injected into the build when running "bun run app:build").
VERIFIER_URL=https://your-tlsn-verifier.example.com
PROXY_URL=wss://your-tlsn-verifier.example.com/proxy
